# ─── Base de données ──────────────────────────────────────
# Format : postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:ASHNBF47op**@localhost:5432/cineradar"

# ─── Redis ────────────────────────────────────────────────
# Format : redis://[:PASSWORD@]HOST:PORT
REDIS_URL="redis://localhost:6379"

# ─── Serveur ──────────────────────────────────────────────
PORT=3003
NODE_ENV="development"

# ─── Emails (Resend) ──────────────────────────────────────
# Obtenez votre clé sur https://resend.com
RESEND_API_KEY="re_89LDaisR_LK7FGmL9qGA6aLbGG7Q7LhrR"
# Adresse expéditrice vérifiée dans Resend
EMAIL_FROM="CinéRadar <onboarding@resend.dev>"

# ─── Scraping ─────────────────────────────────────────────
# Délai entre les requêtes scraper (ms) pour ne pas surcharger les serveurs
SCRAPER_DELAY_MS=2500
# Expression cron du job de scraping
# "0 6 * * 3" = tous les mercredis à 6h (jour de sortie des films en France)
# "0 6 * * *" = tous les jours à 6h (pour les tests/dev)
SCRAPE_CRON="0 6 * * 3"

# ─── APIs externes ────────────────────────────────────────
# TMDB (The Movie Database) — posters + bandes annonces
# Clé gratuite : https://www.themoviedb.org/settings/api
TMDB_API_KEY="c1a06170108a599bdca4179917973319"

# OMDB — fallback affiches (facultatif)
# Clé gratuite : http://www.omdbapi.com/apikey.aspx
OMDB_API_KEY="e6307810"

# ─── URL du frontend (pour les liens dans les emails) ────
SITE_URL="http://localhost:3002"

# ─── Admin ────────────────────────────────────────────────
