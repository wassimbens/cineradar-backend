# ─── Base de données ────────────────────────────────────────
# Format : postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:CHANGE_ME@localhost:5432/cineradar"

# ─── Redis (optionnel — cache désactivé si absent) ──────────
REDIS_URL="redis://localhost:6379"

# ─── Serveur ────────────────────────────────────────────────
PORT=3003
NODE_ENV="development"

# ─── Emails (Resend — https://resend.com) ───────────────────
RESEND_API_KEY="re_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
EMAIL_FROM="CinéRadar <onboarding@resend.dev>"

# ─── Scraping ───────────────────────────────────────────────
SCRAPER_DELAY_MS=2500
SCRAPE_CRON="0 6 * * *"

# ─── Admin ──────────────────────────────────────────────────
ADMIN_SECRET="change-me-in-production"

# ─── URL du frontend (pour les liens dans les emails) ───────
SITE_URL="http://localhost:3002"
# En production : SITE_URL="https://cineradar.fr"

# ─── CORS (production uniquement) ───────────────────────────
# FRONTEND_URL="https://votre-site.vercel.app"
