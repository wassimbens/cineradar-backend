# ─── Base de données ──────────────────────────────────────
# PostgreSQL en production (remplacer par vos vraies valeurs)
DATABASE_URL="postgresql://cineradar_user:VOTRE_MOT_DE_PASSE_FORT@localhost:5432/cineradar_prod"

# ─── Redis ────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── Serveur ──────────────────────────────────────────────
PORT=3003
NODE_ENV="production"

# ─── Emails (Resend) ──────────────────────────────────────
RESEND_API_KEY="re_VOTRE_CLE_RESEND_PRODUCTION"
# Une fois le domaine cineradar.fr vérifié sur Resend :
EMAIL_FROM="CinéRadar <noreply@cineradar.fr>"

# ─── Scraping ─────────────────────────────────────────────
SCRAPER_DELAY_MS=2500
SCRAPE_CRON="0 6 * * 3"  # Chaque mercredi à 6h

# ─── APIs externes ────────────────────────────────────────
TMDB_API_KEY="VOTRE_CLE_TMDB"
OMDB_API_KEY="VOTRE_CLE_OMDB"

# ─── URLs ─────────────────────────────────────────────────
SITE_URL="https://cineradar.fr"
FRONTEND_URL="https://cineradar.fr"

# ─── Sécurité ─────────────────────────────────────────────
# Générer avec : openssl rand -hex 32
ADMIN_SECRET="GENERER_AVEC_openssl_rand_hex_32"
JWT_SECRET="GENERER_AVEC_openssl_rand_hex_32"

# ─── Stripe ───────────────────────────────────────────────
# Clés disponibles sur https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_live_VOTRE_CLE_SECRETE_STRIPE"
STRIPE_WEBHOOK_SECRET="whsec_VOTRE_WEBHOOK_SECRET"
# ID du prix mensuel créé dans Stripe Dashboard > Products
STRIPE_PRICE_ID="price_VOTRE_PRICE_ID"
