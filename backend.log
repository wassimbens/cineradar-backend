prisma:query SELECT COUNT(*) FROM (SELECT "public"."Film"."id" FROM "public"."Film" WHERE 1=1 OFFSET $1) AS "sub"
prisma:query SELECT "public"."Film"."id", "public"."Film"."titre", "public"."Film"."titreOriginal", "public"."Film"."synopsis", "public"."Film"."affiche", "public"."Film"."duree", "public"."Film"."genres", "public"."Film"."realisateur", "public"."Film"."acteurs", "public"."Film"."annee", "public"."Film"."tmdbId", "public"."Film"."imdbId", "public"."Film"."tmdbPopularite", "public"."Film"."tmdbNote", "public"."Film"."imdbNote", "public"."Film"."imdbVotes", "public"."Film"."createdAt", "public"."Film"."updatedAt", COALESCE("aggr_selection_0_Seance"."_aggr_count_seances", 0) AS "_aggr_count_seances" FROM "public"."Film" LEFT JOIN (SELECT "public"."Seance"."filmId", COUNT(*) AS "_aggr_count_seances" FROM "public"."Seance" WHERE "public"."Seance"."dateHeure" >= $1 GROUP BY "public"."Seance"."filmId") AS "aggr_selection_0_Seance" ON ("public"."Film"."id" = "aggr_selection_0_Seance"."filmId") WHERE 1=1 ORDER BY "public"."Film"."titre" ASC OFFSET $2
prisma:query 
        SELECT id FROM "Film"
        WHERE EXISTS (
          SELECT 1 FROM unnest(acteurs) AS a
          WHERE a ILIKE $1
        )
      
prisma:query SELECT COUNT(*) FROM (SELECT "public"."Film"."id" FROM "public"."Film" WHERE ("public"."Film"."titre" ILIKE $1 OR "public"."Film"."titreOriginal" ILIKE $2 OR "public"."Film"."realisateur" ILIKE $3 OR "public"."Film"."id" IN ($4,$5,$6,$7,$8)) OFFSET $9) AS "sub"
prisma:query SELECT "public"."Film"."id", "public"."Film"."titre", "public"."Film"."titreOriginal", "public"."Film"."synopsis", "public"."Film"."affiche", "public"."Film"."duree", "public"."Film"."genres", "public"."Film"."realisateur", "public"."Film"."acteurs", "public"."Film"."annee", "public"."Film"."tmdbId", "public"."Film"."imdbId", "public"."Film"."tmdbPopularite", "public"."Film"."tmdbNote", "public"."Film"."imdbNote", "public"."Film"."imdbVotes", "public"."Film"."createdAt", "public"."Film"."updatedAt", COALESCE("aggr_selection_0_Seance"."_aggr_count_seances", 0) AS "_aggr_count_seances" FROM "public"."Film" LEFT JOIN (SELECT "public"."Seance"."filmId", COUNT(*) AS "_aggr_count_seances" FROM "public"."Seance" WHERE "public"."Seance"."dateHeure" >= $1 GROUP BY "public"."Seance"."filmId") AS "aggr_selection_0_Seance" ON ("public"."Film"."id" = "aggr_selection_0_Seance"."filmId") WHERE ("public"."Film"."titre" ILIKE $2 OR "public"."Film"."titreOriginal" ILIKE $3 OR "public"."Film"."realisateur" ILIKE $4 OR "public"."Film"."id" IN ($5,$6,$7,$8,$9)) ORDER BY "public"."Film"."titre" ASC OFFSET $10
prisma:query 
        SELECT id FROM "Film"
        WHERE EXISTS (
          SELECT 1 FROM unnest(acteurs) AS a
