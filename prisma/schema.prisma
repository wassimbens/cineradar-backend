// backend/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────

enum Version {
  VO
  VF
  VOSTFR
}

// ─── Modèles ─────────────────────────────────────────────

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  pseudo         String?  @unique  // @pseudo public, URL-safe (3-20 chars)
  nom            String?
  avatar         String?  // URL avatar (initiales générées côté front si null)
  bio            String?  // Description libre (cinéphile, amateur, etc.)
  ville          String?  // Ville préférée pour les séances
  isPublic       Boolean  @default(true) // Profil visible publiquement
  emailVerified  Boolean  @default(false) // Email confirmé via lien
  genresPreferes String[] // Ex: ["Drame", "Science-Fiction"]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now()) @updatedAt

  // ── Stripe / Pro ──────────────────────────────────────
  isPremium            Boolean   @default(false)
  premiumUntil         DateTime? // Date d'expiration de l'abonnement
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique

  password            Password?
  following           Follow[]             @relation("follower")
  followers           Follow[]             @relation("followed")
  alertes             Alerte[]
  filmsFavoris        FilmFavori[]
  watchlist           WatchlistItem[]
  cinemasFavoris      CinemaFavori[]
  avis                Avis[]
  filmsVus            FilmVu[]
  emailVerifTokens    EmailVerifToken[]
  passwordResetTokens PasswordResetToken[]
  posterChoices       UserPosterChoice[]
  notifications       Notification[]
  listesCreees        Liste[]             @relation("ListesCreees")
  listeMembres        ListeMembre[]       @relation("ListesMembre")
}

// ── Notifications in-app ──────────────────────────────────
model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // "follow" | "film_en_salle" | "nouveaute_hebdo"
  titre     String
  corps     String?
  lu        Boolean  @default(false)
  lien      String?  // URL relative (ex: /films/abc)
  imageUrl  String?  // Affiche du film ou avatar de l'utilisateur
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, lu])
  @@index([userId, createdAt(sort: Desc)])
}

// Choix d'affiche personnalisée (fonctionnalité Pro)
model UserPosterChoice {
  id        String @id @default(cuid())
  userId    String
  filmId    String
  posterUrl String // URL complète (TMDB w500)
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, filmId]) // un seul choix par film par utilisateur
  @@index([userId])
}

// Token de confirmation d'email (expire dans 24h)
model EmailVerifToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
}

// Token de réinitialisation de mot de passe (expire dans 1h)
model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
}

// Authentification par mot de passe
model Password {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  hash      String   // bcrypt hash
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Système de suivi (follow)
model Follow {
  id          String   @id @default(cuid())
  followerId  String
  follower    User     @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  followedId  String
  followed    User     @relation("followed", fields: [followedId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([followerId, followedId])
  @@index([followedId])
}

// Films favoris (vitrine) — max 4, ordonnés par position
model FilmFavori {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  filmId    String
  film      Film     @relation(fields: [filmId], references: [id], onDelete: Cascade)
  position  Int      @default(0) // 1-4 pour la vitrine
  createdAt DateTime @default(now())

  @@unique([userId, filmId])
  @@index([userId])
}

// Films à voir (watchlist)
model WatchlistItem {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  filmId    String
  film      Film     @relation(fields: [filmId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, filmId])
  @@index([userId])
}

// Cinémas favoris d'un utilisateur
model CinemaFavori {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cinemaId  String
  cinema    Cinema   @relation(fields: [cinemaId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, cinemaId])
  @@index([userId])
}

// Avis et notes sur un film
model Avis {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  filmId    String
  film      Film     @relation(fields: [filmId], references: [id], onDelete: Cascade)
  note      Float?   // 0.5 à 5 (demi-étoiles)
  texte     String?  // Critique textuelle
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, filmId])
  @@index([filmId])
}

model Film {
  id            String   @id @default(cuid())
  titre         String
  titreOriginal String?
  synopsis      String?
  affiche       String? // URL vers l'image d'affiche
  duree         Int? // Durée en minutes
  genres        String[]
  realisateur   String?
  acteurs       String[]
  annee         Int?
  tmdbId        String?  @unique // Identifiant TMDB
  imdbId        String?  @unique // Identifiant IMDB (ex: tt0816692)
  tmdbPopularite Float   @default(0) // Score de popularité TMDB
  tmdbNote      Float?              // Note TMDB (0–10, usage interne/tri)
  imdbNote      Float?              // Note IMDB (0–10, affichée aux utilisateurs)
  imdbVotes     Int?                // Nombre de votes IMDB
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  seances        Seance[]
  alertes        Alerte[]
  filmsFavoris   FilmFavori[]
  watchlistItems WatchlistItem[]
  avis           Avis[]
  filmsVus       FilmVu[]
  listesFilm     ListeFilm[]
}

// Historique de visionnage : films vus par l'utilisateur
// Permet les stats (genres préférés, réalisateurs, cinémas visités…)
model FilmVu {
  id       String   @id @default(cuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  filmId   String
  film     Film     @relation(fields: [filmId], references: [id], onDelete: Cascade)
  // Contexte optionnel
  cinemaId String?  // Cinéma où le film a été vu
  dateVu   DateTime @default(now())
  // On autorise revoir un film : pas de @@unique([userId, filmId])
  // Mais on fournit un index pour les stats
  @@index([userId])
  @@index([filmId])
}

model Cinema {
  id         String  @id @default(cuid())
  nom        String
  adresse    String
  ville      String
  codePostal String
  latitude   Float?
  longitude  Float?
  siteWeb    String?
  telephone  String?
  chaine     String? // "UGC", "MK2", "Pathé", null = indépendant

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  salles         Salle[]
  cinemasFavoris CinemaFavori[]
}

model Salle {
  id       String @id @default(cuid())
  nom      String // "Salle 1", "Grande Salle", etc.
  capacite Int?

  cinemaId String
  cinema   Cinema @relation(fields: [cinemaId], references: [id], onDelete: Cascade)

  seances Seance[]
}

model Seance {
  id        String   @id @default(cuid())
  dateHeure DateTime
  version   Version
  format    String? // "2D", "3D", "IMAX", "Dolby Atmos"
  langue    String? // langue audio si différente de la version
  prix      Float?
  source    String // "ugc", "mk2", "pathe" — traçabilité du scraper

  filmId  String
  film    Film   @relation(fields: [filmId], references: [id], onDelete: Cascade)
  salleId String
  salle   Salle  @relation(fields: [salleId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  notifications SeanceNotifiee[]

  @@index([filmId, dateHeure])
  @@index([salleId, dateHeure])
}

model Alerte {
  id        String  @id @default(cuid())
  email     String
  filmTitre String // Titre saisi par l'utilisateur (avant match en BDD)
  ville     String
  rayon     Int     @default(10) // Rayon en km
  active    Boolean @default(true)

  // Renseigné une fois que le film est trouvé/créé en BDD
  filmId String?
  film   Film?   @relation(fields: [filmId], references: [id], onDelete: SetNull)

  // Optionnel : rattachement à un compte utilisateur
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  notifications SeanceNotifiee[]

  @@index([email])
  @@index([filmId, ville])
}

// ─── Listes thématiques ──────────────────────────────────
// Une liste peut être personnelle ou collaborative (membres).
// Un slug unique permet le partage via URL.

model Liste {
  id          String   @id @default(cuid())
  titre       String
  description String?
  slug        String   @unique // URL-safe, ex: "films-2024-avec-marie"
  isPublic    Boolean  @default(true)
  emoji       String   @default("🎬")

  authorId String
  author   User   @relation("ListesCreees", fields: [authorId], references: [id], onDelete: Cascade)

  films   ListeFilm[]
  membres ListeMembre[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([authorId])
  @@index([slug])
}

model ListeFilm {
  id       String @id @default(cuid())
  position Int    @default(0)
  note     String? // note privée sur ce film dans cette liste

  listeId String
  liste   Liste  @relation(fields: [listeId], references: [id], onDelete: Cascade)

  filmId String
  film   Film   @relation(fields: [filmId], references: [id], onDelete: Cascade)

  addedAt DateTime @default(now())

  @@unique([listeId, filmId])
  @@index([listeId, position])
}

model ListeMembre {
  id   String         @id @default(cuid())
  role ListeMembreRole @default(VIEWER)

  listeId String
  liste   Liste  @relation(fields: [listeId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation("ListesMembre", fields: [userId], references: [id], onDelete: Cascade)

  joinedAt DateTime @default(now())

  @@unique([listeId, userId])
}

enum ListeMembreRole {
  VIEWER
  EDITOR
  ADMIN
}

// Table de liaison : évite d'envoyer deux fois le même email pour la même alerte+séance
model SeanceNotifiee {
  id String @id @default(cuid())

  alerteId String
  alerte   Alerte @relation(fields: [alerteId], references: [id], onDelete: Cascade)

  seanceId String
  seance   Seance @relation(fields: [seanceId], references: [id], onDelete: Cascade)

  envoyeAt DateTime @default(now())

  @@unique([alerteId, seanceId]) // Contrainte d'unicité : une notif par couple
}
